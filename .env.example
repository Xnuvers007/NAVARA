# ==============================================================
# 🛡️ NAVARA (Navigasi Aman Berkendara) - Environment Setup 🛡️
# ==============================================================

# --------------------------------------------------------------
# 1. Konfigurasi Server
# --------------------------------------------------------------
# Port yang akan digunakan oleh server. (Default: 8080)
PORT=8080

# Mode Lingkungan (development / production)
NODE_ENV=development

# --------------------------------------------------------------
# 2. Pengaturan Keamanan API (Anti-CSRF & CORS)
# --------------------------------------------------------------
# Domain resmi aplikasi Anda untuk mencegah pencurian request dari web lain.
# Jika Anda melakukan deploy ke domain khusus, ubah URL di bawah ini.
# Contoh: https://navara-app.com
ALLOWED_ORIGIN=http://localhost:8080

# --------------------------------------------------------------
# 3. Kredensial & Otorisasi
# --------------------------------------------------------------
# Kunci rahasia untuk Hak Akses Administrator.
# Dibutuhkan untuk menghapus laporan secara permanen dari peta.
# Ganti dengan password yang rumit jika di-deploy ke production!
ADMIN_SECRET=admin123
